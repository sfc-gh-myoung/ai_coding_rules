# ============================================================================
# Main Command Dispatch
# ============================================================================

# Default to help if no arguments
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    # ========================================================================
    # Environment
    # ========================================================================
    env:python)
        check_uv
        $UV python install 3.11
        $UV python pin 3.11
        $UV venv
        ;;
    
    env:sync)
        check_uv
        $UV sync --all-groups
        ;;
    
    env:deps)
        check_uv
        $UV lock
        $UV sync --all-groups
        ;;
    
    env:lock)
        check_uv
        $UV lock
        ;;

    # ========================================================================
    # Code Quality
    # ========================================================================
    lint|quality:lint)
        check_uv
        $UV run ruff check .
        ;;
    
    format|quality:format)
        check_uv
        $UV run ruff format --check .
        ;;
    
    lint:fix|quality:lint:fix)
        check_uv
        $UV run ruff check --fix .
        ;;
    
    format:fix|quality:format:fix)
        check_uv
        $UV run ruff format .
        ;;
    
    typecheck|quality:typecheck|type)
        check_uv
        $UV run ty check .
        ;;
    
    typecheck:watch|quality:typecheck:watch)
        check_uv
        $UV run ty check . --watch
        ;;
    
    markdown|quality:markdown)
        check_uvx
        $UVX pymarkdownlnt --config pymarkdown.rules.json scan rules/ templates/AGENTS_MODE.md.template templates/AGENTS_NO_MODE.md.template PROJECT.md
        $UVX pymarkdownlnt --config pymarkdown.docs.json scan docs/ README.md CONTRIBUTING.md CHANGELOG.md
        ;;
    
    quality:check)
        check_uv
        check_uvx
        $UV run ruff check .
        $UV run ruff format --check .
        $UV run ty check .
        $UVX pymarkdownlnt --config pymarkdown.rules.json scan rules/ templates/AGENTS_MODE.md.template templates/AGENTS_NO_MODE.md.template PROJECT.md
        $UVX pymarkdownlnt --config pymarkdown.docs.json scan docs/ README.md CONTRIBUTING.md CHANGELOG.md
        ;;
    
    quality:fix|fix|qf)
        check_uv
        $UV run ruff check --fix .
        $UV run ruff format .
        ;;

    # ========================================================================
    # Testing
    # ========================================================================
    test|test:all)
        check_uv
        $UV run pytest tests/ --tb=short
        ;;
    
    test:coverage)
        check_uv
        $UV run pytest --cov=scripts --cov-report=term-missing --cov-report=html tests/
        ;;
    
    test:coverage:open)
        check_uv
        $UV run pytest --cov=scripts --cov-report=term-missing --cov-report=html tests/
        # Detect platform and open
        if [[ "$OSTYPE" == "darwin"* ]]; then
            open htmlcov/index.html
        elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
            xdg-open htmlcov/index.html
        else
            echo "Coverage report generated at htmlcov/index.html"
        fi
        ;;

    # ========================================================================
    # Rules Management
    # ========================================================================
    rules:validate)
        check_uv
        $PYTHON scripts/schema_validator.py rules/
        ;;
    
    rules:validate:verbose)
        check_uv
        $PYTHON scripts/schema_validator.py rules/ --verbose
        ;;
    
    examples:validate)
        check_uv
        $PYTHON scripts/schema_validator.py rules/examples/ --examples
        ;;
    
    examples:validate:verbose)
        check_uv
        $PYTHON scripts/schema_validator.py rules/examples/ --examples --verbose
        ;;
    
    index:generate)
        check_uv
        $PYTHON scripts/index_generator.py
        ;;
    
    index:check)
        check_uv
        $PYTHON scripts/index_generator.py --check
        ;;
    
    index:dry)
        check_uv
        $PYTHON scripts/index_generator.py --dry-run
        ;;
    
    rule:new)
        check_uv
        require_arg "FILENAME" "rule:new" "$@"
        FILENAME="$PARSED_ARG"
        
        # Build optional args
        CMD="$PYTHON scripts/template_generator.py \"$FILENAME\""
        parse_arg "OUTPUT_DIR" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --output-dir \"$PARSED_ARG\""
        OUTPUT_DIR_VAL="${PARSED_ARG:-}"
        parse_arg "TIER" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --context-tier \"$PARSED_ARG\""
        parse_arg "KEYWORDS" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --keywords '$PARSED_ARG'"
        
        eval "$CMD"
        echo "✅ Template created. Next steps:"
        echo "1. Edit the file and replace placeholders"
        echo "2. Validation will run automatically below..."
        $PYTHON scripts/schema_validator.py "${OUTPUT_DIR_VAL:-rules}/${FILENAME}.md" --verbose
        ;;
    
    rule:new:force)
        check_uv
        require_arg "FILENAME" "rule:new:force" "$@"
        FILENAME="$PARSED_ARG"
        
        # Build optional args
        CMD="$PYTHON scripts/template_generator.py \"$FILENAME\" --force"
        parse_arg "OUTPUT_DIR" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --output-dir \"$PARSED_ARG\""
        OUTPUT_DIR_VAL="${PARSED_ARG:-}"
        parse_arg "TIER" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --context-tier \"$PARSED_ARG\""
        parse_arg "KEYWORDS" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --keywords '$PARSED_ARG'"
        
        eval "$CMD"
        echo "✅ Template created (overwritten). Next steps:"
        echo "1. Edit the file and replace placeholders"
        echo "2. Validation will run automatically below..."
        $PYTHON scripts/schema_validator.py "${OUTPUT_DIR_VAL:-rules}/${FILENAME}.md" --verbose
        ;;

    # ========================================================================
    # Deployment
    # ========================================================================
    deploy)
        check_uv
        require_arg "DEST" "deploy" "$@"
        DEST="$PARSED_ARG"
        
        CMD="$PYTHON scripts/rule_deployer.py --dest \"$DEST\""
        has_flag "NO_MODE" "$@" && CMD="$CMD --no-mode"
        
        eval "$CMD"
        ;;
    
    deploy:dry)
        check_uv
        require_arg "DEST" "deploy:dry" "$@"
        DEST="$PARSED_ARG"
        
        CMD="$PYTHON scripts/rule_deployer.py --dest \"$DEST\" --dry-run"
        has_flag "NO_MODE" "$@" && CMD="$CMD --no-mode"
        
        eval "$CMD"
        ;;
    
    deploy:verbose)
        check_uv
        require_arg "DEST" "deploy:verbose" "$@"
        DEST="$PARSED_ARG"
        
        CMD="$PYTHON scripts/rule_deployer.py --dest \"$DEST\" --verbose"
        has_flag "NO_MODE" "$@" && CMD="$CMD --no-mode"
        
        eval "$CMD"
        ;;
    
    deploy:no-skills)
        check_uv
        require_arg "DEST" "deploy:no-skills" "$@"
        DEST="$PARSED_ARG"
        
        $PYTHON scripts/rule_deployer.py --dest "$DEST" --skip-skills
        ;;
    
    deploy:only-skills)
        check_uv
        require_arg "DEST" "deploy:only-skills" "$@"
        DEST="$PARSED_ARG"
        
        $PYTHON scripts/rule_deployer.py --dest "$DEST" --only-skills
        ;;
    
    deploy:no-mode)
        check_uv
        require_arg "DEST" "deploy:no-mode" "$@"
        DEST="$PARSED_ARG"
        
        CMD="$PYTHON scripts/rule_deployer.py --dest \"$DEST\" --no-mode"
        has_flag "DRY_RUN" "$@" && CMD="$CMD --dry-run"
        
        eval "$CMD"
        ;;
    
    deploy:split)
        check_uv
        require_arg "AGENTS" "deploy:split" "$@"
        AGENTS="$PARSED_ARG"
        
        CMD="$PYTHON scripts/rule_deployer.py --agents-dest \"$AGENTS\""
        parse_arg "RULES" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --rules-dest \"$PARSED_ARG\""
        parse_arg "SKILLS" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --skills-dest \"$PARSED_ARG\""
        has_flag "NO_MODE" "$@" && CMD="$CMD --no-mode"
        has_flag "DRY_RUN" "$@" && CMD="$CMD --dry-run"
        has_flag "FORCE" "$@" && CMD="$CMD --force"
        
        eval "$CMD"
        ;;
    
    deploy:split:dry)
        check_uv
        require_arg "AGENTS" "deploy:split:dry" "$@"
        AGENTS="$PARSED_ARG"
        
        CMD="$PYTHON scripts/rule_deployer.py --agents-dest \"$AGENTS\" --dry-run"
        parse_arg "RULES" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --rules-dest \"$PARSED_ARG\""
        parse_arg "SKILLS" "$@" && [[ -n "$PARSED_ARG" ]] && CMD="$CMD --skills-dest \"$PARSED_ARG\""
        
        eval "$CMD"
        ;;

    # ========================================================================
    # Token Management
    # ========================================================================
    tokens:update)
        check_uv
        $PYTHON scripts/token_validator.py rules/
        ;;
    
    tokens:check)
        check_uv
        $PYTHON scripts/token_validator.py rules/ --dry-run --detailed
        ;;
    
    tokens:dry)
        check_uv
        $PYTHON scripts/token_validator.py rules/ --dry-run
        ;;
    
    tokens:update:file)
        check_uv
        require_arg "FILE" "tokens:update:file" "$@"
        $PYTHON scripts/token_validator.py "$PARSED_ARG"
        ;;
    
    tokens:check:file)
        check_uv
        require_arg "FILE" "tokens:check:file" "$@"
        $PYTHON scripts/token_validator.py "$PARSED_ARG" --dry-run --detailed
        ;;

    # ========================================================================
    # Keyword Management
    # ========================================================================
    keywords:suggest)
        check_uv
        require_arg "FILE" "keywords:suggest" "$@"
        $PYTHON scripts/keyword_generator.py "$PARSED_ARG" --corpus
        ;;
    
    keywords:diff)
        check_uv
        require_arg "FILE" "keywords:diff" "$@"
        $PYTHON scripts/keyword_generator.py "$PARSED_ARG" --corpus --diff
        ;;
    
    keywords:update)
        check_uv
        require_arg "FILE" "keywords:update" "$@"
        $PYTHON scripts/keyword_generator.py "$PARSED_ARG" --corpus --update
        ;;
    
    keywords:all)
        check_uv
        $PYTHON scripts/keyword_generator.py rules/ --corpus
        ;;

    # ========================================================================
    # Badges
    # ========================================================================
    badges:update)
        check_uv
        $UV run pytest --cov=scripts --cov-report=term-missing --cov-report=html tests/
        $PYTHON scripts/badge_updater.py
        ;;

    # ========================================================================
    # Validation & CI
    # ========================================================================
    preflight)
        # Check prerequisites
        if ! command -v uv &>/dev/null; then
            echo "ERROR: uv not found. Install: https://docs.astral.sh/uv/"
            exit 1
        fi
        if [[ ! -f pyproject.toml ]]; then
            echo "ERROR: pyproject.toml not found. Run from project root."
            exit 1
        fi
        if [[ ! -f ./dev ]]; then
            echo "ERROR: ./dev not found. Run from project root."
            exit 1
        fi
        echo "Environment ready"
        ;;
    
    validate|validate:ci|ci)
        check_uv
        check_uvx
        # Run all checks sequentially
        echo "Running quality:lint..."
        $UV run ruff check .
        echo "Running quality:format..."
        $UV run ruff format --check .
        echo "Running quality:typecheck..."
        $UV run ty check .
        echo "Running quality:markdown..."
        $UVX pymarkdownlnt --config pymarkdown.rules.json scan rules/ templates/AGENTS_MODE.md.template templates/AGENTS_NO_MODE.md.template PROJECT.md
        $UVX pymarkdownlnt --config pymarkdown.docs.json scan docs/ README.md CONTRIBUTING.md CHANGELOG.md
        echo "Running test..."
        $UV run pytest tests/ --tb=short
        echo "Running rules:validate..."
        $PYTHON scripts/schema_validator.py rules/
        echo "Running examples:validate..."
        $PYTHON scripts/schema_validator.py rules/examples/ --examples
        echo "Running index:check..."
        $PYTHON scripts/index_generator.py --check
        echo "All validation checks passed!"
        ;;

    # ========================================================================
    # Cleanup
    # ========================================================================
    clean)
        scripts/clean.sh
        ;;
    
    clean:cache)
        scripts/clean.sh cache
        ;;
    
    clean:venv)
        scripts/clean.sh venv
        ;;
    
    clean:all)
        scripts/clean.sh all
        ;;

    # ========================================================================
    # Status
    # ========================================================================
    status)
        scripts/status.sh
        ;;

    # ========================================================================
    # Help
    # ========================================================================
    help|-h|--help)
        show_help
        ;;

    # ========================================================================
    # Unknown Command
    # ========================================================================
    *)
        echo "ERROR: Unknown command '$COMMAND'"
        echo ""
        echo "Run './dev help' to see available commands."
        exit 1
        ;;
esac
