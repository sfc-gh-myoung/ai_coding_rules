#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# dev - Single entry point for AI Coding Rules development commands
# Replaces Taskfile.yml with a portable bash wrapper
# ============================================================================

# Auto-detect tool paths
UV=$(command -v uv || echo "uv")
UVX=$(command -v uvx || echo "uvx")
PROJECT_VERSION=$(awk -F'"' '/^version = "/ {print $2; exit}' pyproject.toml 2>/dev/null || echo "unknown")
PYTHON="$UV run python"

# ============================================================================
# Helper Functions
# ============================================================================

check_uv() {
    if ! command -v uv &>/dev/null; then
        echo "ERROR: uv not found. Install: https://docs.astral.sh/uv/"
        exit 1
    fi
}

check_uvx() {
    if ! command -v uvx &>/dev/null; then
        echo "ERROR: uvx not found. Install uv (includes uvx): https://docs.astral.sh/uv/"
        exit 1
    fi
}

# Parse argument - supports both VAR=value and positional styles
# Usage: parse_arg "VAR_NAME" "$@"
# Returns value in $PARSED_ARG
parse_arg() {
    local var_name="$1"
    shift
    PARSED_ARG=""
    
    for arg in "$@"; do
        # Check for VAR=value style
        if [[ "$arg" == "${var_name}="* ]]; then
            PARSED_ARG="${arg#${var_name}=}"
            return 0
        fi
    done
    
    # Check for positional (first non-flag argument after subcommand)
    for arg in "$@"; do
        if [[ "$arg" != *"="* && "$arg" != -* ]]; then
            PARSED_ARG="$arg"
            return 0
        fi
    done
    
    return 1
}

# Parse optional boolean flag (VAR=true style)
# Usage: has_flag "VAR_NAME" "$@"
has_flag() {
    local var_name="$1"
    shift
    for arg in "$@"; do
        if [[ "$arg" == "${var_name}=true" ]]; then
            return 0
        fi
    done
    return 1
}

# Require an argument or exit with error
require_arg() {
    local var_name="$1"
    local command="$2"
    shift 2
    if ! parse_arg "$var_name" "$@"; then
        echo "ERROR: $var_name is required for '$command'"
        echo "Usage: ./dev $command $var_name=<value>"
        echo "   or: ./dev $command <value>"
        exit 1
    fi
    if [[ -z "$PARSED_ARG" ]]; then
        echo "ERROR: $var_name is required for '$command'"
        echo "Usage: ./dev $command $var_name=<value>"
        echo "   or: ./dev $command <value>"
        exit 1
    fi
}

